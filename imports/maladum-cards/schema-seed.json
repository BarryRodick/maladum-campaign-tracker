        "mode": "reaction"
      },
      {
        "id": "fortified-mind",
        "name": "Fortified Mind",
        "type": "skill",
        "rulesText": "1. Use before casting a spell to cast it while engaged.\n2. Reaction: Use when friend in short range suffers an attack. Use this character's magical armour. Pegs from this character and/or target may be used. Magic Die effects are applied to this character.\n3. Until end of round, all spells targeting friends in short range are resisted for free (unless they are Unstoppable). Attacks against friends in short range may use this character's magical armour. Pegs from this character and/or target may be used. Magic Die effects are applied to this character. Passive: When casting spells of level lower than rank, do not become Fatigued after Mental Overload result.",
        "tags": [
          "magus",
          "profession"
        ],
        "source": {
          "name": "reference-magus.pdf",
          "url": "imports/maladum-cards/reference-magus.pdf"
        }
      },
      {
        "id": "frenzy-magus",
        "name": "Frenzy",
        "type": "skill",
        "rulesText": "1. Use before melee attack to roll +2 dice.\n2. Use before melee attack to roll +3 dice.\n3. Use before melee attack to roll +4 dice. Hits may be split between targets in range of weapon. Additional effects are applied to all enemies hit. Passive: Gain First Strike.",
        "tags": [
          "magus",
          "profession"
        ],
        "source": {
          "name": "reference-magus.pdf",
          "url": "imports/maladum-cards/reference-magus.pdf"
        },
        "mode": "active"
      },
      {
