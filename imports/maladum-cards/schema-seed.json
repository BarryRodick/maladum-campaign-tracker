      {
        "id": "onslaught",
        "name": "Onslaught",
        "type": "skill",
        "rulesText": "1. Reaction: Use after scoring hits in melee. Make a Melee Attack.\n2. Reaction: Use after scoring hits with an attack. You may Move and then make a Melee Attack.\n3. Use during a Move. Ignore AoO. You may make a Melee Attack against each enemy engaged while moving.",
        "tags": [
          "guardian",
          "profession"
        ],
        "source": {
          "name": "reference-guardian.pdf",
